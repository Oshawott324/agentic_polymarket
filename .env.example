:120,"trust_tier":"curated","asset_symbol":"USD/EUR","price_path":"rates.EUR","category":"fx"},{"key":"frankfurter-usd-jpy","adapter":"http_json_price","url":"https://api.frankfurter.app/latest?from=USD&to=JPY","poll_interval_seconds":120,"trust_tier":"curated","asset_symbol":"USD/JPY","price_path":"rates.JPY","category":"fx"},{"key":"stooq-spx","adapter":"http_csv_price","url":"https://stooq.com/q/l/?s=^spx&i=d","poll_interval_seconds":300,"trust_tier":"exchange","asset_symbol":"SPX","price_path":"close","category":"equity"},{"key":"stooq-gold","adapter":"http_csv_price","url":"https://stooq.com/q/l/?s=gc.f&i=d","poll_interval_seconds":300,"trust_tier":"exchange","asset_symbol":"GOLD","price_path":"close","category":"commodity"},{"key":"stooq-wti","adapter":"http_csv_price","url":"https://stooq.com/q/l/?s=cl.f&i=d","poll_interval_seconds":300,"trust_tier":"exchange","asset_symbol":"WTI","price_path":"close","category":"commodity"},{"key":"reddit-worldnews-new","adapter":"reddit_api_subreddit_new","poll_interval_seconds":60,"trust_tier":"curated","subreddit":"worldnews","limit":40,"category":"world"},{"key":"reddit-economics-new","adapter":"reddit_api_subreddit_new","poll_interval_seconds":60,"trust_tier":"curated","subreddit":"Economics","limit":40,"category":"business"},{"key":"bbc-business-news","adapter":"news_rss","url":"https://feeds.bbci.co.uk/news/business/rss.xml","poll_interval_seconds":60,"trust_tier":"curated","category":"business","resolution_extraction_mode":"agent_extract"},{"key":"bbc-technology-news","adapter":"news_rss","url":"https://feeds.bbci.co.uk/news/technology/rss.xml","poll_interval_seconds":60,"trust_tier":"curated","category":"technology","resolution_extraction_mode":"agent_extract"},{"key":"reddit-sports-new","adapter":"reddit_api_subreddit_new","poll_interval_seconds":60,"trust_tier":"curated","subreddit":"sports","limit":40,"category":"sports"}]'
