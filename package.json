{
  "name": "automakit",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "pnpm -r --if-present build && pnpm build:matching-engine",
    "build:matching-engine": "cargo check --manifest-path services/matching-engine/Cargo.toml",
    "dev": "./scripts/dev.sh",
    "dev:autonomous:native": "./scripts/dev-autonomous-native.sh",
    "dev:infra": "./scripts/dev-infra.sh",
    "dev:matching-engine": "cargo run --manifest-path services/matching-engine/Cargo.toml",
    "live:test": "tsx scripts/live-test.ts",
    "live:test:agent-auth": "tsx scripts/live-test-agent-auth.ts",
    "live:test:streams": "tsx scripts/live-test-streams.ts",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.1.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "pg": "^8.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "ws": "^8.18.3"
  }
}
