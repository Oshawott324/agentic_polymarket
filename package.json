{
  "name": "agentic-polymarket",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:matching-engine": "cargo check --manifest-path services/matching-engine/Cargo.toml",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:infra": "docker compose -f infra/docker/docker-compose.yml up",
    "dev:matching-engine": "cargo run --manifest-path services/matching-engine/Cargo.toml",
    "live:test": "tsx scripts/live-test.ts",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
